offset_left = 0.0
offset_top = 0.0
offset_right = 1280.0
offset_bottom = 720.0
color = Color(0.949, 0.929, 0.878, 1.0)
z_index = -1

[node name="Camera2D" type="Camera2D" parent="."]
## 主攝影機，預設跟隨視窗中心
